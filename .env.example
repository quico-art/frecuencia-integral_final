# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Variables de entorno del monorepo AulaOS
# Copia este archivo como .env en la raíz y rellena los valores reales.
# NUNCA subas .env a Git (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────


# ── API SERVER (artifacts/api-server) ─────────────────────────────────────────

# Clave secreta para firmar las sesiones Express.
# Genera una cadena aleatoria larga: openssl rand -hex 32
SESSION_SECRET=

# Claves de Stripe (obtén las tuyas en dashboard.stripe.com > Developers > API keys)
STRIPE_SECRET_KEY=sk_live_...        # o sk_test_... en desarrollo
STRIPE_PUBLISHABLE_KEY=pk_live_...   # o pk_test_... en desarrollo


# ── SUPABASE — compartida por todos los frontends ─────────────────────────────
# Encuéntralas en: supabase.com > Tu proyecto > Settings > API

# URL del proyecto (ej: https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon key (segura para el frontend, respeta las Row Level Security policies)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role key (SOLO para el servidor, nunca exponer en el frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── OPCIONALES ────────────────────────────────────────────────────────────────

# Nivel de logs del servidor (debug | info | warn | error). Default: info
LOG_LEVEL=info

# Puerto local para cada app (en Replit lo asigna automáticamente)
# En local puedes asignarlos manualmente si hay conflictos:
# PORT_LMS=3001
# PORT_FI=3002
# PORT_ACADEMY=3003
# PORT_API=3004
